# -----------------------------------------------------------------------------
# Supabase (auth + Postgres)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Lemon Squeezy (pagos)
# -----------------------------------------------------------------------------
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_SIGNING_SECRET=

# -----------------------------------------------------------------------------
# Resend (emails transaccionales)
# -----------------------------------------------------------------------------
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Cloudflare R2 (storage / CDN)
# -----------------------------------------------------------------------------
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_ENDPOINT=
# URL pública del bucket (dominio custom conectado en R2 > Settings > Custom Domains)
NEXT_PUBLIC_R2_CDN_URL=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# URL absoluta del sitio en producción. Sin trailing slash.
# Required: app/sitemap.ts y app/robots.ts tiran error en build si falta.
SITE_URL=https://virel.com
